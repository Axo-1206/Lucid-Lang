package test

-- 1. Structs with function-typed fields
struct MathOps {
    -- Parameter names are required in function types
    add (a int, b int) int
    transform (n int) int
}

struct Point {
    x float = 0 -- set default value
    y float
}

let test_point2 Point = Point { y = 5 }
-- let test_point3 Point = Point { a = 1 } -- error y must be assign an initial value because y is not nullable and doesn't have a default value

-- 2. Implementation with methods (curried and normal)
impl Point {
    -- Normal method
    magSquared () float = {
        return x * x + y * y
    }

    -- Curried method
    -- The instance is implicitly the first parameter of the first group.
    -- To partial apply the instance: p:offset
    offset (dx float) (dy float) Point = {
        return Point { x = x + dx, y = y + dy }
    }
}

-- 3. Type Conversion using 'from' block
struct Seconds { val int }
struct Minutes { val int }

from Minutes {
    -- Allows conversion: Minutes(seconds)
    (s Seconds) Minutes = {
        return Minutes { val = s.val / 60 }
    }
}

-- 4. Global functions with currying
-- Proper curry syntax uses separate parameter groups
const core_add (a int) (b int) int = {
    return a + b
}

-- 5. Async function and await
-- Async block form for named function
let computeAsync (x int) int = async {
    -- In Luc, await can be used on values or async calls
    let val int = await x 
    return val * 2
}

-- 6. Main Entry Point demonstrating all features
export const main () int = {
    -- Function Assignment
    -- Assigning a curried function reference
    let myAdd (a int) (b int) int = core_add
    let res1 int = myAdd(10)(20)() -- should this throw an error at compile-time or runtime? since the function myAdd doesn't support a third call

    -- Function Currying (Partial Application)
    -- Calling first group returns a function for the second group
    let addFive (n int) int = core_add(5)
    let res2 int = addFive(10) -- results in 15

    -- Function value from struct
    let ops MathOps = MathOps {
        add = (a int, b int) int { return a + b }, -- anonymous function
        transform = addFive
    }
    let res3 int = ops.add(1, 2)
    let res4 int = ops.transform(10)
    let res6 int = ops.add(1) -- should throw a semantic error, missing argument

    -- Method Assignment and Currying via ':' operator
    let p Point = Point { x = 1.0, y = 2.0 }
    
    -- ':' as a postfix operator (as per grammar) references the method.
    -- For an instance method, it curries 'self'.
    -- If offset is (self Point) (dx float) (dy float) Point
    -- Then p:offset is (dx float) (dy float) Point
    let movePoint (dx float) (dy float) Point = p:offset
    
    -- Partial apply one more level
    let moveRight (dy float) Point = movePoint(10.0)
    let p2 Point = moveRight(5.0) 

    -- Type Conversion via 'from' block usage
    let s Seconds = Seconds { val = 120 }
    let m Minutes = Minutes(s) -- dispatch to Minutes.from.sec
    let minutesVal int = m.val

    -- Anonymous Function (Async and Curried)
    let anonAsync (n int) (m int) int = async (n int) (m int) int {
        return await n + m
    }
    
    -- Calling async function
    let asyncRes int = computeAsync(10)
    let anonRes int = anonAsync(20)(30)

    -- Pipeline with curried functions
    -- f1 takes an int and returns a function
    let f1 (x int) (y int) int = {
        return x + y
    }

    -- f2 takes a function as input and calls it
    let f2 (fn (a int) int) int = {
        return fn(10)
    }

    -- Pipeline: 5 -> f1 produces (y int) int { return 5 + y }
    -- Then that function is piped into f2, which calls it with 10. Result: 15
    let pipeRes int = 5 -> f1 -> f2

    return 0
}
