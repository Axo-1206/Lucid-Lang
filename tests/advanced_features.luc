-- advanced_features.luc
-- Tests advanced and edge-case syntax: generic from, generic impl, generic trait,
-- re-exports, attributes, complex operators, multi-assign to fields/indexes, etc.

package advanced

-- ============================================================================
-- Re-export (export use) – top-level only
-- ============================================================================

export use math.vec2          -- re-export all pub items from math.vec2
export use math.matrix.Mat2   -- granular re-export

-- ============================================================================
-- @deprecated attribute on various declarations
-- ============================================================================

@deprecated("use Vec2 instead")
struct OldPoint {
    x int
    y int
}

@deprecated("use newAdd")
let oldAdd (a int, b int) -> int = { return a + b }

@deprecated("use GlobalConst")
const oldConst int = 42

-- ============================================================================
-- @extern on variables (extern global symbol)
-- ============================================================================

@extern("__stack_top")
const stackTop *uint8

@extern("errno")
const errnoPtr *int

-- ============================================================================
-- Generic trait with generic impl
-- ============================================================================

trait Converter<A, B> {
    convert (src A) -> B
}

struct Wrapper<T> {
    value T
}

impl Wrapper<T> : Converter<T, int>  {
    convert (src T) -> int = {
        return int(src)   -- relies on implicit conversion
    }
}

-- ============================================================================
-- Generic from block with multiple param groups (curried conversion)
-- ============================================================================

struct Radians { value float }
struct Degrees { value float }

from Degrees {
    (rad Radians)(mult float) -> Degrees = {
        return Degrees { value = rad.value * mult * (180.0 / 3.14159) }
    }
}

let rad Radians = Radians { value = 1.0 }
let deg Degrees = rad(57.2958)   -- curried call: rad(57.2958) returns Degrees

-- ============================================================================
-- Generic type alias with constraints (though constraints are semantic)
-- ============================================================================

type HashableMap<K : Hashable, V> = [*]V
type ComparableSlice<T : Comparable> = []T

-- ============================================================================
-- Complex if expression (chained with else if)
-- ============================================================================

let score int = 85
let grade string = if score >= 90 ?? "A" else if score >= 80 ?? "B" else if score >= 70 ?? "C" else "F"

-- ============================================================================
-- Null coalescing (??) chaining
-- ============================================================================

let a int? = nil
let b int? = nil
let c int = 42
let result int = a ?? b ?? c   -- 42

-- ============================================================================
-- Safe navigation (?.) chaining
-- ============================================================================

struct Address {
    city string
    zip string?
}
struct Person {
    name string
    address &Address?
}
let p Person? = nil
let cityName string? = p?.address?.city
let zipCode string? = p?.address?.zip ?? "unknown"

-- ============================================================================
-- Power assignment (^=)
-- ============================================================================

let powerVal int = 2

-- ============================================================================
-- Multi-assignment to fields and indices (reassignment form)
-- ============================================================================

struct MutablePair {
    first int
    second int
}
let pair MutablePair = MutablePair { first = 10, second = 20 }
let arr [*]int = [1, 2, 3]

@aot
export const main (args []string) -> int = {
    io.printl("Running advanced tests")
    
    -- Multi-assign with function returning multiple values
    let update () -> (int, int) = { return 5, 6 }
    pair.first, arr[0] = update()

    -- ============================================================================
    -- Bitwise assignment operators
    -- ============================================================================

    let bits int = 0b1100
        bits &&= 0b1010   -- bits = 0b1000
        bits ||= 0b0001   -- bits = 0b1001
        bits ~^= 0b1111   -- bits = 0b0110
        bits <<= 2        -- bits = 0b11000
        bits >>= 1        -- bits = 0b01100

    -- ============================================================================
    -- For loop with range and implicit type (defaults to int)
    -- ============================================================================

    let sum int = 0
    for i in 0..10 {        -- i inferred as int
        sum = sum + i
    }

    -- For loop with step and explicit type (redundant but allowed)
    for i int in 0..20..2 {
        sum = sum + i
    }

    -- For loop over array (slice/dynamic)
    let items [*]string = ["a", "b", "c"]
    for item in items {
        io.printl(item)
    }

    -- ============================================================================
    -- While and do-while (already tested but include for completeness)
    -- ============================================================================

    let counter int = 0
    while counter < 3 {
        counter = counter + 1
    }
    do {
        counter = counter - 1
    } while counter > 0

    -- ============================================================================
    -- Break and continue in nested loops
    -- ============================================================================

    for i in 0..5 {
        for j in 0..5 {
            if i == 2 and j == 2 { break }
            if j % 2 == 0 { continue }
            sum = sum + i + j
        }
    }

    -- ============================================================================
    -- Match expression with `is` pattern and struct pattern with wildcard
    -- ============================================================================

    let data any = Wrapper<int> { value = 42 }
    let description string = match data {
        w is Wrapper<int> if w.value > 0 => "positive wrapper"
        Wrapper { value: 0 } => "zero wrapper"
        _ => "other"
        default => ""
    }

    -- Match with secondary values from some arms (second variable nullable)
    let primary string
    let secondary string?
    primary, secondary = match data {
        w is Wrapper<int> => "wrapper", "value=" + string(w.value)
        _ => "unknown"    -- secondary becomes nil
        default => ""
    }

    -- ============================================================================
    -- Raw string literals with multiple # delimiters (already, but more examples)
    -- ============================================================================

    let rawSimple string = r"hello\nworld"                    -- literal backslash-n
    let rawDoubleQuote string = r#"She said "Hello""#         -- contains double quote
    -- let rawTriple string = r##"Embedded "#" and "##"##        -- contains "# and "##
    let rawRegex string = r"^\d{3}-\d{2}-\d{4}$"

    -- ============================================================================
    -- Doc comments (attached to following declaration)
    -- ============================================================================

    /--
    - This struct represents a 3D vector.
    - # Example
    - ```
    - let v Vector3 = Vector3 { x = 1.0, y = 2.0, z = 3.0 }
    - ```
    --/
    struct Vector3 {
        x float
        y float
        z float
    }

    -- Single-line doc comment attached to function
    -- Returns the Euclidean norm of the vector.
    let norm (v Vector3) -> float = {
        return #sqrt(v.x*v.x + v.y*v.y + v.z*v.z)
    }

    -- ============================================================================
    -- Const with enum variant (compile-time constant)
    -- ============================================================================

    enum ShaderType {
        Vertex = 1
        Fragment = 2
        Compute = 4
    }
    const defaultShader ShaderType = ShaderType.Vertex

    -- ============================================================================
    -- Variadic parameters (advanced: passing slice as variadic argument)
    -- ============================================================================

    let sumAll (nums ...int) -> int = {
        let total int = 0
        for n in nums {
            total = total + n
        }
        return total
    }

    let values [*]int = [1, 2, 3, 4]
    let total int = sumAll(values)  

    -- ============================================================================
    -- Catch step with Error type (already, but ensure syntax with block)
    -- ============================================================================

    struct DivisionError { msg string }
    let safeDiv (a int, b int) -> (int, DivisionError?) = {
        if b == 0 { return 0, DivisionError { msg = "zero divisor" } }
        return a / b, nil
    }
    let quotient int = safeDiv(10, 0) |> (e Error) {
        io.printl("Error: " + e.msg)
        return -1
    }

    -- ============================================================================
    -- Pipeline with `!` on method calls (argument pack)
    -- ============================================================================

    impl Vector3 {
        scale (factor float) -> Vector3 = {
            return Vector3 { x = x * factor, y = y * factor, z = z * factor }
        }
    }
    let v Vector3 = Vector3 { x = 1.0, y = 2.0, z = 3.0 }
    let doubled Vector3 = v |> Vector3:scale(2.0)!   -- argument pack

    -- ============================================================================
    -- Composition (+>) with qualified functions (qualifiers on result binding)
    -- ============================================================================

    let asyncFetch ~async (url string) -> string = { return "data" }
    let asyncProcess ~async (data string) -> int = { return data.len() }
    let pipeline ~async (url string) -> int = asyncFetch +> asyncProcess   -- result binding carries ~async

    -- ============================================================================
    -- ~parallel qualifier (body restrictions not checked syntactically, but parser must accept)
    -- ============================================================================

    let parallelMap<T, U> ~parallel (items [*]T, f (item T) -> U) -> [*]U = {
        let result [*]U = []
        for i in 0..<items.len() {
            result.push(f(items[i]))
        }
        return result
    }

    -- function/struct member/field/array access - call
    test[0]:abds() -- the array contain struct, we are calling the behavior member of the struct
    test[0].abc() -- succeed
    funcTest():abc() -- the function return a struct so we calling its behavior member
    funcTest().testA() -- succeed
    arrayTest()[0].testB() -- succeed
    arrayTest()[0]:testB() -- same problem as above
    -- complex tests
    arrayTest()[1]()()[2].abc() -- succeed

    -- Verify some results (compiler would check, here just parsing)
    let check int = sumAll(1, 2, 3)   -- 6
    let check2 int = powerVal          -- should be 8
    let check3 int = pair.first        -- should be 5 (from update)

    return 0
}