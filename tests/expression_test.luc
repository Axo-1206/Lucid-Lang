-- tests/expression_test.luc
package test

-- ============================================================================
-- EXPRESSION TESTS: bitwise, comparison, logical operators
-- with @jit flag on main (default for now)
-- ============================================================================

-- Top-level declarations only (no statements)
let a uint32 = 0xFF00
let b uint32 = 0x0F0F

-- bitwise operators (compile-time constant expressions, allowed at top-level)
let andResult uint32 = a && b   -- 0x0F00
let orResult  uint32 = a || b   -- 0xFF0F
let xorResult uint32 = a ~^ b   -- 0xF00F
let notResult uint32 = ~a       -- 0xFFFF00FF (on 32-bit)

let shifted uint32 = 1 << 4     -- 16
let halved  uint32 = 256 >> 2   -- 64

-- Comparison operators (compile-time constant expressions)
let five int = 5
let alsoFive int = 5
let eq   bool = five == alsoFive
let neq  bool = five != alsoFive
let less bool = 3 < 5
let greater bool = 7 > 5
let le   bool = 5 <= 5
let ge   bool = 5 >= 5

-- Logical operators (compile-time constants)
let x int = 5
let y int = 10
let andBool bool = x > 0 and y < 20
let orBool  bool = x < 0 or y > 5
let notBool bool = not true

-- Nullable logical test constants
let nullable int? = nil
let notNil bool = not nullable        -- true
let andNil bool = nullable and x > 0  -- false
let orNil  bool = nullable or x > 0   -- true

-- Reference equality (needs runtime values, so not const; will be inside main)
struct Point { x float; y float }

-- Entry point with @jit (default for now)
@aot
export const main () int = {
    -- ------------------------------------------------------------------------
    -- Bitwise compound assignments (must be inside main, not top-level)
    -- ------------------------------------------------------------------------
    let flags uint32 = 0x01
    flags &&= 0x03      -- bitwise AND then assign
    flags ||= 0x08      -- bitwise OR then assign
    flags ~^= 0x02      -- bitwise XOR then assign

    -- ------------------------------------------------------------------------
    -- Comparison operators that need runtime values
    -- ------------------------------------------------------------------------
    let p1 Point = Point { x = 1.0, y = 2.0 }
    let p2 Point = p1                -- copy
    let sameAddr bool = p1 === p2    -- false (different memory)
    let ref1 &Point = p1
    let ref2 &Point = p1
    let sameRef bool = ref1 === ref2 -- true

    -- "is" operator with runtime narrowing
    let value any = 42
    let isInt bool = value is int    -- true
    if value is int {
        let n int = value + 1        -- value narrowed to int
        let dummy int = n            -- use n to avoid unused warning
    }

    -- ------------------------------------------------------------------------
    -- Short-circuit test (verify no side-effects at compile time)
    -- ------------------------------------------------------------------------
    let sideEffect int = 0
    let Short bool = false and (sideEffect = 1; true)
    let shortOr bool = true or (sideEffect = 2; false)
    -- sideEffect should still be 0 (the right-hand sides were not evaluated)

    -- ------------------------------------------------------------------------
    -- Negative test for chained comparisons (commented, uncomment to verify E3014)
    -- ------------------------------------------------------------------------
    -- if 0 < x < 10 { }    -- ERROR: chained comparison not allowed

    -- ------------------------------------------------------------------------
    -- Grouped expressions with parentheses
    -- ------------------------------------------------------------------------
    let test1 bool = (x > 0) and (y < 20)
    let test2 bool = (x < 0) or not (y == 5)

    -- ------------------------------------------------------------------------
    -- Use all computed values to avoid "unused" warnings (optional)
    -- ------------------------------------------------------------------------
    let dummy uint32 = flags
    let dummy2 bool = sameAddr and sameRef
    let dummy3 bool = isInt
    let dummy4 bool = test1 and test2
    let dummy5 bool = Short and shortOr

    return 0
}