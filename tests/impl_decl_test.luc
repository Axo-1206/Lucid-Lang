-- impl_decl_test.luc
-- Tests the 'impl declaration' section from LUC_GRAMMAR.md
-- This file covers various impl blocks: target types, 'as' alias, trait conformance,
-- injection form (!), plain assignment, generic parameters, independent generics,
-- and array impls (concrete and generic).

package test

-- ============================================================
-- 1. Basic struct and enum definitions for impl targets
-- ============================================================

struct Vec2 {
    x float
    y float
}

struct Box<T> {
    value T
}

enum Direction {
    North
    South
    East
    West
}

type IntList = [_, int]
type ID = int

-- ============================================================
-- 2. Trait definitions
-- ============================================================

trait Drawable {
    draw   ()
    bounds () -> Rect
}

trait Comparable<T> {
    compareTo (other T) -> int
}

trait Hashable {
    hash   () -> uint64
    equals (other any) -> bool
}

struct Rect {
    w float
    h float
}

-- ============================================================
-- 3. Impl blocks without 'as' -> receiver is 'self'
-- ============================================================

impl Vec2 {
    length () -> float = {
        return #sqrt(self.x * self.x + self.y * self.y)
    }
}

-- ============================================================
-- 4. Impl blocks with 'as' alias
-- ============================================================

impl Vec2 as v {
    normalize () -> Vec2 = {
        let len float = v:length()
        if len == 0.0 { return Vec2 { x = 0.0, y = 0.0 } }
        return Vec2 { x = v.x / len, y = v.y / len }
    }
}

impl int as i {
    isEven () -> bool = { return i % 2 == 0 }
    isOdd  () -> bool = { return i % 2 != 0 }
}

-- ============================================================
-- 5. Trait conformance (impl Type : Trait)
-- ============================================================

impl Circle : Drawable {
    draw   () = { /- ... -/ }
    bounds () -> Rect = { return Rect { w = 10.0, h = 10.0 } }
}

struct Circle {
    radius float
    center Vec2
}

impl int : Comparable<int> {
    compareTo (other int) -> int = {
        if self > other { return 1 }
        if self < other { return -1 }
        return 0
    }
}

-- ============================================================
-- 6. Plain assignment methods (no injection, function exposed as-is)
-- ============================================================

-- Helper function
const getVersion () -> string = { return "1.0.0" }

impl int as i {
    version = getVersion     -- method type: () -> string
}

-- ============================================================
-- 7. Injection form (!) – fixing the receiver
-- ============================================================

export const intToStr (n int) -> string = { return string(n) }
export const clamp (n int, lo int, hi int) -> int = {
    if n < lo { return lo }
    if n > hi { return hi }
    return n
}
export const intFormat (n int, prefix string) -> string = {
    return prefix + string(n)
}

impl int as i {
    -- Remove first parameter (n) and fix it with i
    toStr = intToStr(i)!            -- resolved: () -> string
    format = intFormat(i)!          -- resolved: (prefix string) -> string
    -- Remove first parameter from multi-param function
    clamped = clamp(i)!             -- resolved: (lo int, hi int) -> int
}

-- Injection with generic function
export const identity<T> (v T) -> T = { return v }

impl int as i {
    id = identity<int>(i)!          -- resolved: () -> int
}

-- ============================================================
-- 8. Generic struct impl with matching generic parameters
-- ============================================================

impl Box<T> as b {
    get () -> T = { return b.value }
    set (v T) = { b.value = v }
}

-- ============================================================
-- 9. Independent generic parameters on methods
-- ============================================================

export const convert<T, U> (v T, f (T) -> U) -> U = { return f(v) }

impl Box<T> as b {
    -- Dependent T from Box<T>, independent U on method
    -- map<U> (fn (T) -> U) -> Box<U> = {
    --     return Box<U> { value = fn(b.value) }
    -- }

    -- Using injection with mixed dependent/independent
    convert = convert<T, int>(b)!   -- T dependent, int concrete
    -- resolved: (fn (T) -> int) -> int
}

-- ============================================================
-- 10. Impl on primitive type alias (same as primitive)
-- ============================================================

impl ID as id {
    isZero () -> bool = { return id == 0 }
}

-- ============================================================
-- 11. Impl on array types (concrete element)
-- ============================================================

impl [_, int] as s {
    sum () -> int = {
        let total int = 0
        for v int in s { total += v }
        return total
    }
    product () -> int = {
        let result int = 1
        for v int in s { result *= v }
        return result
    }
}

impl [*, int] as a {
    pushAll (values [_, int]) = {
        for v int in values { a:push(v) }
    }
    popN (n int) -> [*, int] = {
        let result [*, int] = []
        for i int in 0..<n { result:push(a:pop()) }
        return result
    }
}

impl [4, float] as f4 {
    dot (other [4, float]) -> float = {
        let sum float = 0.0
        for i int in 0..3 { sum = sum + f4[i] * other[i] }
        return sum
    }
}

-- ============================================================
-- 12. Impl on generic array type using <T> inside brackets
-- ============================================================

-- Generic slice method that refers to element type T
impl [_, <T>] as list {
    first () -> T = { return list[0] }
    last  () -> T = { return list[list:len() - 1] }
    isEmpty () -> bool = { return list:len() == 0 }
}

-- Generic dynamic array methods
impl [*, <T>] as arr {
    push (v T) = { _dynarrayPush(#toPtr(arr), #toPtr(v)) }
    pop  () -> T = { return #toRef(_dynarrayPop(#toPtr(arr))) }
}

-- @extern declarations for array internals (mock)
@extern("luc_dynarray_push")
const _dynarrayPush (arr *uint8, elem *uint8)

@extern("luc_dynarray_pop")
const _dynarrayPop  (arr *uint8) -> *uint8

-- ============================================================
-- 13. Impl on type alias of array (same as underlying array)
-- ============================================================

impl IntList as l {
    average () -> float = {
        let sum int = l:sum()
        let count uint64 = l:len()
        if count == 0 { return 0.0 }
        return float(sum) / float(count)
    }
}

-- ============================================================
-- 14. Impl on enums
-- ============================================================

impl Direction as d {
    opposite () -> Direction = {
        match d {
            Direction.North => return Direction.South
            Direction.South => return Direction.North
            Direction.East  => return Direction.West
            Direction.West  => return Direction.East
        }
        default => return Direction.North
    }
    isHorizontal () -> bool = {
        return d == Direction.East or d == Direction.West
    }
}

-- ============================================================
-- 15. Using the impl methods (call sites)
-- ============================================================

export const main () -> int = {
    -- primitive methods
    let a int = 5
    let even bool = a:isEven()      -- false
    let version string = a:version()  -- "1.0.0"
    let str string = a:toStr()        -- "5"
    let formatted string = a:format("Value: ")  -- "Value: 5"
    let clamped int = a:clamped(0, 10)          -- 5

    -- struct methods
    let v Vec2 = Vec2 { x = 3.0, y = 4.0 }
    let len float = v:length()           -- 5.0
    let norm Vec2 = v:normalize()

    -- array methods
    let nums [_, int] = [1, 2, 3, 4]
    let sum int = nums:sum()            -- 10
    let avg float = nums:average()      -- 2.5

    let dyn [*, int] = [10, 20]
    dyn:push(30)
    let popped int = dyn:pop()          -- 30

    -- generic array methods
    let first int = nums:first()        -- 1
    let last int = nums:last()          -- 4

    -- generic struct methods
    let b Box<int> = Box<int> { value = 42 }
    let val int = b:get()               -- 42
    let b2 Box<string> = b:map<string>(intToStr)  -- Box<string> { value = "42" }

    -- enum methods
    let dir Direction = Direction.North
    let opp Direction = dir:opposite()  -- Direction.South
    let horiz bool = dir:isHorizontal() -- false

    -- injection with generic identity
    let idVal int = a:id()              -- 5

    return 0
}

-- ============================================================
-- 16. Visibility modifiers on impl blocks
-- ============================================================

pub impl Vec2 {
    pub getX () -> float = { return self.x }
    export getY () -> float = { return self.y }
    -- private methods (no modifier) are file-visible only
    internal () -> float = { return self.x + self.y }
}

-- ============================================================
-- 17. Impl blocks within local scopes (no pub/export allowed)
-- ============================================================

let localTest () -> int = {
    struct Point { x int, y int }

    impl Point as p {
        magnitude () -> int = { return p.x * p.x + p.y * p.y }
    }

    let pt Point = Point { x = 3, y = 4 }
    return pt:magnitude()   -- 25
}

-- ============================================================
-- 18. Error cases (commented out)
-- ============================================================

-- ERROR: function types cannot implement traits
-- type Predicate = (int) -> bool
-- impl Predicate : Drawable { ... }

-- ERROR: duplicate method name in same impl block
-- impl int {
--     isEven () -> bool = { ... }
--     isEven () -> bool = { ... }  -- duplicate
-- }

-- ERROR: injection with variadic @extern
-- @extern("printf")
-- const printf (fmt *uint8, args ...any) -> int
-- impl string as s {
--     print = printf(s)!  -- invalid, variadic
-- }

-- ERROR: mismatched arity for generic impl
-- struct Pair<K,V> { first K, second V }
-- impl Pair<T> { ... }  -- needs 2 parameters

-- ============================================================
-- 19. Overlapping impl resolution (scope proximity)
-- ============================================================

-- This is for demonstration; resolution depends on import order
-- and last-declared wins.

impl int {
    describe () -> string = { return "int from base" }
}

impl int {
    describe () -> string = { return "int from second" }  -- shadows the first
}

let testOverlap = 42:describe()   -- "int from second"

-- ============================================================
-- 20. Impl for generic array via type alias (equivalent to inline <T>)
-- ============================================================

type Slice<T> = [_, T]

impl Slice<T> as s {
    middle () -> T = {
        let idx int = int(s:len() / 2)
        return s[idx]
    }
}

let testSlice [_, float] = [1.0, 2.0, 3.0, 4.0]
let mid float = testSlice:middle()   -- 3.0 (index 2)

-- ============================================================
-- End of test file
