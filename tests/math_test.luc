-- tests/math_test.luc
package math_test

---------------------------------------------
-- 1. Basic arithmetic on numeric types (should succeed)
---------------------------------------------
let a int = 10
let b int = 3
let sum int = a + b
let diff int = a - b
let prod int = a * b
let quot int = a / b
let rem int = a % b
let pow int = a ^ b   -- exponentiation

let x float = 3.5
let y float = 2.0
let fsum float = x + y
let fprod float = x * y

-- Mixed numeric types - widening allowed (int -> float)
let mixed float = a + x   -- 10 + 3.5 = 13.5

---------------------------------------------
-- 2. Arithmetic on struct types (should error)
---------------------------------------------
struct Vec2 { x float; y float }

let v1 Vec2 = Vec2 { x = 1.0, y = 2.0 }
let v2 Vec2 = Vec2 { x = 3.0, y = 4.0 }

-- All of these should be semantic errors
-- let badSum Vec2 = v1 + v2      -- ERROR: operator '+' not defined for struct Vec2
-- let badSub Vec2 = v1 - v2      -- ERROR: operator '-' not defined ...
-- let badMul Vec2 = v1 * v2      -- ERROR: operator '*' not defined ...
-- let badDiv Vec2 = v1 / v2      -- ERROR: operator '/' not defined ...
-- let badPow Vec2 = v1 ^ v2      -- ERROR: operator '^' not defined ...

---------------------------------------------
-- 3. Arithmetic on function types (should error)
---------------------------------------------
let fn1 (x int) int = { return x * 2 }
let fn2 (x int) int = { return x + 1 }

-- let badCall = fn1 + fn2        -- ERROR: cannot add function types
-- let badCall2 = fn1 - fn2       -- ERROR: operator '-' on functions

---------------------------------------------
-- 4. String operations
---------------------------------------------
let s1 string = "hello"
let s2 string = " world"
let concat string = s1 + s2   -- OK: string concatenation

-- String multiplication? Not supported in Luc grammar/semantic.
-- The following should be rejected:
-- let repeated string = s1 * 5   -- ERROR: '*' not defined for string * int
-- let repeated2 string = 5 * s1  -- ERROR: '*' not defined for int * string

-- const variables cannot be mutated
const MAX int = 100
-- MAX += 1        -- ERROR: cannot assign to const

-- Non‑numeric compound assignment (should be rejected)
let msg string = "hi"
-- msg += " there"      -- ERROR: string does not support '+='? (decide if allowed)
                         -- Leaving as comment – currently we assume it's an error.

---------------------------------------------
-- 6. Unary operators
---------------------------------------------
let pos int = 5
let neg int = -pos     -- OK
let notBool bool = not true   -- OK on bool (logical)
-- let notInt = not 5   -- ERROR: 'not' requires bool or nullable

let bitwise int = ~pos  -- OK: bitwise NOT on integer
let ref  int= &pos          -- OK: reference operator

-- Unary minus on non‑numeric
let v Vec2 = Vec2 { x = 1.0, y = 2.0 }
-- let negV = -v        -- ERROR: unary '-' not defined for struct

---------------------------------------------
-- 7. Pointer arithmetic (should be disallowed)
---------------------------------------------
-- Raw pointers are only allowed inside @extern, but even there arithmetic is forbidden.
@extern("example")
const ptr *uint8? = nil

-- let ptr2 = ptr + 1   -- ERROR: arithmetic on raw pointer not allowed
-- let ptr3 = ptr - 1   -- ERROR: arithmetic on raw pointer not allowed

-- Use @ptrOffset instead (test that intrinsic is available)
let offset *uint8? = @ptrOffset(ptr, 1)   -- OK: intrinsic handles arithmetic safely

---------------------------------------------
-- 8. Division by zero (compile-time constant detection)
---------------------------------------------
const ZERO int = 0
-- let divZero int = 5 / ZERO   -- Should produce a compile-time error or warning
                                 -- (depending on language design). We'll leave as comment.

---------------------------------------------
-- End of tests – the file should compile successfully only if all ERRORS are raised.
---------------------------------------------

export const main () int = {
    ---------------------------------------------
    -- 5. Compound assignments (only on let variables)
    ---------------------------------------------
    let counter int = 0
    counter += 5      -- OK
    counter -= 2
    counter *= 10
    counter /= 3
    counter ^= 2
    counter %= 7

    return 0
}