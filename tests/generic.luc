-- ============================================================================
-- Generic pipeline (|>) with generic functions
-- ============================================================================

let toBox<T> (x T) -> Box<T> = { return Box<T> { value = x } }
let fromBox<T> (b Box<T>) -> T = { return b.value }

let pipelineResult int = 100 |> toBox<int> |> fromBox<int>

