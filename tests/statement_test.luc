-- tests/statement_test.luc
package statement_test

-- ============================================================================
-- STATEMENT TESTS: switch, while, do-while, break, continue
-- with logical/unary operators in conditions and pipeline/composition inside bodies
-- ============================================================================

-- Helper functions for pipeline tests
let doubleValue (x int) int = { return x * 2 }
let toString (x int) string = { return string(x) }
let isPositive (x int) bool = { return x > 0 }

-- Composition example
let process (x int) float = doubleValue +> toString   -- (int) string

export const main () int = {

    -- ========================================================================
    -- SECTION 1: Logical and unary operators in conditions
    -- ========================================================================

    let a int = 5
    let b int = 10
    let flag bool = true
    let nullable int? = nil

    -- 1.1 Logical operators (and, or, not)
    if a > 0 and b < 20 {
        -- OK
    }

    if a > 0 or b > 100 {
        -- OK
    }

    if not flag {
        -- OK
    }

    if nullable is int and nullable > 0 {  -- 'is' narrows type
        -- OK
    }

    -- 1.2 Unary operators (-, ~, &)
    let neg int = -a
    let bitwise int = ~a
    let ref &int = a    -- reference

    -- 1.3 Chained comparisons (should be error)
    -- if 0 < a < 10 { }  -- ERROR: chained comparison not allowed; use 'and'

    -- ========================================================================
    -- SECTION 2: while loop with logical condition and pipeline body
    -- ========================================================================

    let counter int = 0
    while counter < 5 and flag {
        -- pipeline inside body (without I/O, just assignment)
        let step int = counter -> doubleValue
        let s string = step -> toString   -- discard result
        counter += 1
    }

    -- 2.1 while with unary negation in condition
    let done bool = false
    while not done {
        done = true
    }

    -- ========================================================================
    -- SECTION 3: do-while loop (body executed at least once)
    -- ========================================================================

    let steps int = 0
    do {
        let s int = steps -> doubleValue
        steps += 1
    } while steps < 3

    -- 3.1 do-while with 'or' condition
    let x int = 0
    do {
        x += 1
    } while x == 0 or x < 5   -- stops after x=5

    -- ========================================================================
    -- SECTION 4: switch statement (value dispatch, no fallthrough)
    -- ========================================================================

    let code int = 200

    switch code {
        case 200, 201: {
            let s1 string = "success"
        }
        case 400: {
            let s2 string = "client error"
        }
        case 500: {
            let s3 string = "server error"
        }
        default: {
            let s4 string = "unknown"
        }
    }

    -- 4.2 switch with range cases (inclusive .. and exclusive ..<)
    let damage int = 5
    switch damage {
        case 0: {
            let _s1 string = "none"
        }
        case 1..10: {
            let _s2 string = "light"      -- inclusive: 1-10
        }
        case 11..<50: {
            let _s3 string = "moderate"   -- exclusive: 11-49
        }
        default: {
            let _s4 string = "critical"
        }
    }

    -- 4.3 switch with pipeline in case body
    let val int = 42
    switch val {
        case 42: {
            let result string = val -> doubleValue -> toString
        }
        default: {
            let s5 string = val -> toString
        }
    }

    -- ========================================================================
    -- SECTION 5: break and continue inside loops
    -- ========================================================================

    let i int = 0
    while i < 10 {
        i += 1
        if i == 5 {
            continue   -- skip printing 5
        }
        if i > 7 {
            break
        }
        let s6 string = i -> toString
    }

    -- 5.2 Nested loops: break exits the innermost loop
    let outer int = 0
    while outer < 3 {
        let inner int = 0
        while inner < 5 {
            if inner == 2 {
                break   -- exits inner loop only
            }
            inner += 1
        }
        outer += 1
    }

    -- ========================================================================
    -- SECTION 6: Pipeline and composition as main execution inside bodies
    -- ========================================================================

    -- 6.1 Pipeline seed -> step (using function reference)
    let seed int = 10
    let result string = seed -> doubleValue -> toString
    -- result == "20"

    -- 6.2 Pipeline with argument pack (!)
    let scale (v int, factor int) int = { return v * factor }
    let scaled int = seed -> scale(3)!   -- 10 -> scale(10, 3) = 30
    let n1 int = scaled -> doubleValue

    -- 6.3 Pipeline with anonymous function step
    let data int = 7
    let label string = data -> (x int) string {
        return if x > 5 ?? "big" else "small"
    }

    -- 6.4 Composition (+) used inside a function body
    let composed (x int) string = process   -- process = doubleValue +> toString
    let msg string = composed(25)  -- "50"

    -- 6.5 Composition inside pipeline (as a step)
    let comp = doubleValue +> toString
    let s7 string = 42 -> comp   -- "84"

    -- ========================================================================
    -- SECTION 7: Edge cases and error expectations (commented)
    -- ========================================================================

    -- 7.1 break outside loop (should error)
    -- break   -- ERROR: 'break' must be inside a loop

    -- 7.2 continue outside loop (should error)
    -- continue   -- ERROR: 'continue' must be inside a loop

    -- 7.3 switch without default (allowed, but default is optional)
    let color int = 1
    switch color {
        case 1: { let s10 string = "red" }
        case 2: { let s11 string = "green" }
    }   -- no default, fine

    -- 7.4 duplicate case value (should error)
    -- switch 1 {
    --     case 1: {}
    --     case 1: {}   -- ERROR: duplicate case value
    -- }

    let test (i int, j int) = {}
    5 -> test(1)!

    return 0
}