-- ============================================================================
-- Basic functions
-- ============================================================================

let add (a int, b int) -> int = {
    return a + b
}

let log (msg string) = {
    -- io.printl would be used in real code; here just a comment
}

let divmod (a int, b int) -> (int, int) = {
    return a / b, a % b
}

-- ============================================================================
-- Qualifiers
-- ============================================================================

let fetch ~async (url string) -> string = {
    return "ok"
}

let maybeFind ~nullable (items [*]int, target int) -> int? = nil

let parallelFor<T> ~parallel (items [*]T, body (item T)) = {
    -- body must obey ~parallel restrictions (no return, no writes to outer scope)
}

-- ============================================================================
-- Curry
-- ============================================================================

let addCurry (a int)(b int) -> int = {
    return a + b
}

let clamp (min int)(max int)(value int) -> int = {
    if value < min { return min }
    if value > max { return max }
    return value
}

-- Partial application via closure
let multiplier int = 3
let scale (x int) -> int = (x int) -> int { return x * multiplier }

-- ============================================================================
-- Generic functions
-- ============================================================================

let map<T, U> (items [*]T, f (item T) -> U) -> [*]U = {
    let result [*]U = []
    for i int in 0..<items.len() {
        result.push(f(items[i]))
    }
    return result
}

-- With generic constraint
trait Comparable {
    compareTo (other any) -> int
}

let findMax<T : Comparable> (items [*]T) -> T? = {
    if items.isEmpty() { return nil }
    let max T = items[0]
    for i int in 1..<items.len() {
        if items[i].compareTo(max) > 0 {
            max = items[i]
        }
    }
    return max
}

-- ============================================================================
-- Function types and aliases
-- ============================================================================

type Transform = (v Vec2) -> Vec2
type AsyncCallback = ~async (data string) -> int
type NullableFunc = ~nullable (x int) -> int

-- ============================================================================
-- Functions as parameters and return values
-- ============================================================================

let apply (f (x int) -> int, val int) -> int = {
    return f(val)
}

let makeAdder (inc int) -> (x int) -> int = {
    return (x int) -> int { return x + inc }
}

-- ============================================================================
-- Struct and impl method reference
-- ============================================================================

pub struct Vec2 {
    x float
    y float
}

pub impl Vec2 {
    length () -> float = {
        return #sqrt(x*x + y*y)
    }
    normalize () -> Vec2 = {
        let len float = Vec2:length()
        return Vec2 { x = x / len, y = y / len }
    }
}

let lengthFunc () -> float = Vec2:length
let normFunc () -> Vec2 = Vec2:normalize

-- ============================================================================
-- Pipeline and composition
-- ============================================================================

let doubleNumber (x int) -> int = { return x * 2 }
let intToString (x int) -> string = { return "value: " + string(x) }

-- Pipeline
let pipelineResult string = 10 |> doubleNumber()! |> intToString

-- Composition
let doubleThenString (x int) -> string = doubleNumber +> intToString
let composedResult string = doubleThenString(21)

-- Pipeline with method reference
let v Vec2 = Vec2 { x = 3.0, y = 4.0 }
let len float = v |> Vec2:length

-- Argument pack with `!`
let scaleVec (v Vec2, factor float) -> Vec2 = {
    return Vec2 { x = v.x * factor, y = v.y * factor }
}
let scaled Vec2 = v |> scaleVec(2.0)!

