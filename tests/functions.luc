-- ============================================================================
-- SECTION 5: Pipeline Operator with Functions
-- ============================================================================

-- Basic pipeline
-- let pipelineTest () int = {
--     let result = 42 -> double -> string -> len
--     return result
-- }

-- Pipeline with anonymous function step
let anonStepTest = {
    let result = 5 -> (x int) string { return string(x * 10) }
    return result  -- "50"
}

-- Pipeline with argument pack (!)
let scale (v int, factor int) int = {
    return v * factor
}

let pipelineWithPack = {
    let result = 10 -> scale(3)!  -- calls scale(10, 3)
    return result  -- 30
}

-- Pipeline with impl method reference
struct Vec2 { x float  y float }

impl Vec2 {
    length () float = { return (x*x + y*y) }
    normalize () Vec2 = {
        let len = self:length()
        return Vec2 { x = x / len  y = y / len }
    }
}

let methodPipeline = {
    let v Vec2 = Vec2 { x = 3.0  y = 4.0 }
    let result = v -> Vec2:normalize -> Vec2:length
    return result  -- 1.0
}

