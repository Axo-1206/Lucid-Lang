-- test_functions.luc
-- Compiler test file for function declarations, currying, async, and pipelines

package test

-- ============================================================================
-- SECTION 1: Basic Function Declarations
-- ============================================================================

-- Shorthand form with block body
const test (x int) int = {
    return x * 2
}

-- Let function (reassignable)
let greet (name string) string = {
    return "Hello, " + name
}

-- Explicit anonymous function form
let add (a int, b int) int = (a int, b int) int {
    return a + b
}

-- Function with nullable return
let parse (s string) int? = {
    if s == "" {
        return nil
    }
    return 42
}

-- Nullable function variable
let handler (f (req int) string)? = nil

-- ============================================================================
-- SECTION 2: Currying and Partial Application
-- ============================================================================

-- Curried function with two groups
let multiply (a int) (b int) int = {
    return a * b
}

-- Partial application
let doubleVal (x int) int = multiply(2)
let ten int = doubleVal(5)  -- 10

-- Curried function with three groups
let clamp (min int) (max int) (value int) int = {
    if value < min { return min }
    if value > max { return max }
    return value
}

-- Partial application of first two groups
let clamp0to100 (x int) int = clamp(0)(100)
let clamped int = clamp0to100(150)  -- 100

-- ============================================================================
-- SECTION 3: First-Class Functions
-- ============================================================================

-- Type alias for function type
type Transformer = (n int) int

-- Assign function to type alias
let trans Transformer = (x int) int { return x * 3 }

-- Higher-order function
let applyTwice (f (int) int, x int) int = {
    return f(f(x))
}

-- Using higher-order function
let addThree (x int) int = { return x + 3 }
let result int = applyTwice(addThree, 5)  -- 11

-- Function returning a closure
let makeCounter () () int = {
    let count int = 0
    return () int {
        count = count + 1
        return count
    }
}

let counter () int = makeCounter()
let first int = counter()   -- 1
let second int = counter()  -- 2

