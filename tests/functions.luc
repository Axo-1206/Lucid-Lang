    let db double = double(10)           -- 20
    let gt string = greet("World")       -- "Hello, World"
    
    let mult int = multiply(4)(5)     -- 20
    let cl int = clamp(0)(100)(50)    -- 50
    
    let applied int = applyTwice(addThree, 2)  -- 8
    
