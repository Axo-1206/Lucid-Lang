    -- -- ========================================================================
    -- -- If expression (inline form with ?? as separator)
    -- -- ========================================================================
    -- let statusMessage string = if a > 50 ?? "high" else "low"
    -- let nestedIf string = if a < 0 ?? "neg" else if a == 0 ?? "zero" else "pos"

    -- -- ========================================================================
