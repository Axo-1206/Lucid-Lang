    -- -- ========================================================================
    -- switch a {
    --     case 0, 1: { io.printl("small") }
    --     case 2..10: { io.printl("medium") }
    --     case 11..<100: { io.printl("large") }
    --     default: { io.printl("unknown") }
    -- }

    -- ========================================================================
    -- Match expression (with patterns, guards, secondary values)
    -- ========================================================================
    -- let desc string = match a {
    --     0 => "zero"
    --     n if n < 0 => "negative: " + string(n)
    --     n => "positive: " + string(n)
    --     default => "impossible"
    -- }

    -- -- Match with multiple pattern values
    -- let category string = match a {
    --     1, 2, 3 => "low"
    --     4, 5, 6 => "mid"
    --     default => "high"
    -- }

    -- -- Match with range pattern
    -- let rangeDesc string = match a {
    --     0 => "none"
    --     1..10 => "between 1 and 10"
    --     11..<100 => "between 11 and 99"
    --     default => "100 or more"
    -- }

    -- Match with struct pattern
    -- let pt Point = Point { x = 10, y = 20 }
    -- let ptDesc string = match pt {
    --     Point { x: 0, y: 0 } => "origin"
    --     Point { x, y } => "point (" + string(x) + "," + string(y) + ")"
    --     default => "unknown"
    -- }

    -- Match with secondary values (some arms supply second value)
    -- let primary string
    -- let secondary string?
    -- primary, secondary = match a {
    --     200 => "OK", "success"
    --     404 => "Not Found"   -- secondary becomes nil
    --     default => "Unknown"
    -- }

    -- -- ========================================================================
    -- -- While loop
    -- -- ========================================================================
    -- let i int = 0
    -- while i < 5 {
    --     i = i + 1
    -- }

    -- -- ========================================================================
    -- -- Do-while loop
    -- -- ========================================================================
    -- let j int = 0
    -- do {
    --     j = j + 1
    -- } while j < 3

    -- -- ========================================================================
    -- -- For loop with range (inclusive, exclusive, step)
    -- -- ========================================================================
    -- let sum int = 0
    -- for idx int in 0..10 {
    --     sum = sum + idx
    -- }

    -- for idx int in 0..<10 {
    --     sum = sum + idx
    -- }

    -- for step int in 0..20..2 {
    --     sum = sum + step
    -- }

    -- -- For loop over array (dynamic array)
    -- let numbers [*]int = [1, 2, 3, 4, 5]
    -- for num in numbers {
    --     sum = sum + num
    -- }

    -- -- ========================================================================
    -- -- Break and continue
    -- -- ========================================================================
    -- let k int = 0
    -- while k < 10 {
    --     k = k + 1
    --     if k % 2 == 0 { continue }
    --     if k > 7 { break }
    -- }

    -- -- ========================================================================
    -- -- Return statement (void and with value)
    -- -- ========================================================================
    -- let testReturn (x int) -> int = {
    --     if x < 0 { return 0 }
    --     return x * 2
    -- }

    -- -- ========================================================================
    -- -- Pipeline operator (|>)
    -- -- ========================================================================
    -- let Double (x int) -> int = { return x * 2 }
    -- let toString (x int) -> string = { return string(x) }

    -- let pipelineResult string = 5 |> Double |> toString

    -- -- Pipeline with argument pack (!)
    -- let add (a int, b int) -> int = { return a + b }
    -- let pipedAdd int = 10 |> add(5)!

    -- -- Pipeline with method reference
    -- let p Point = Point { x = 3, y = 4 }
    -- let pX int = p |> Point.x  
    -- let xVal int = p |> Point:getX

    -- -- Pipeline with anonymous function
    -- let anonPipeline int = 10 |> (x int) -> int { return x + 5 }

    -- -- ========================================================================
    -- -- Composition operator (+>)
    -- -- ========================================================================
    -- let doubleFn (x int) -> int = { return x * 2 }
    -- let toStringFn (x int) -> string = { return string(x) }
    -- let composed (x int) string = doubleFn +> toStringFn
    -- let composedResult string = composed(42)

    -- -- ========================================================================
    -- -- Null-coalescing operator (??)
    -- -- ========================================================================
    -- let maybe int? = nil
    -- let value int = maybe ?? 100

    -- ========================================================================
    -- Safe navigation operator (?.)
    -- ========================================================================
    type ABC = int
    let test &ABC? = nil
    let test *ABC? = 6

    struct Container {
        data &Point?
    }
    let container Container? = nil
    let coordX int? = container?.data?.x

    -- ========================================================================
    -- Catch step (|> catch)
    -- ========================================================================
    struct Error { msg string }
    let riskyOp (x int) -> (int, Error?) = {
        if x < 0 { return 0, Error { msg = "negative" } }
        return x, nil
    }
    let safeResult int = riskyOp(-5) |> (err Error?) {
        io.printl("Caught: " + err.msg)
        return -1
    }

    -- ========================================================================
    -- Power operator (^) - right-associative
    -- ========================================================================
    let pow1 int = 2 ^ 3        -- 8
    let pow2 int = 2 ^ 3 ^ 2    -- 2^(3^2)=2^9=512

    -- ========================================================================
    -- Bitwise operators (&&, ||, ~^, ~~, <<, >>)
    -- ========================================================================
    let flags uint32 = 0b1100
    let mask uint32 = 0b1010
    let andRes uint32 = flags && mask   -- 0b1000
    let orRes  uint32 = flags || mask   -- 0b1110
    let xorRes uint32 = flags ~^ mask   -- 0b0110
    let notRes uint32 = ~~flags         -- bitwise NOT (on 32 bits)
    let shifted uint32 = flags << 2

    -- ========================================================================
    -- Logical operators (and, or, not) with short-circuit
    -- ========================================================================
    let cond1 bool = true
    let cond2 bool = false
    let logAnd bool = cond1 and cond2
    let logOr  bool = cond1 or cond2
    let logNot bool = not cond1

    -- ========================================================================
    -- Array operations (fixed, slice, dynamic)
    -- ========================================================================
    let fixed [3]int = [10, 20, 30]
    let fixedElem int = fixed[1]
    let slice []int = fixed[0..2]       -- inclusive end
    let sliceExcl []int = fixed[0..<2]   -- exclusive end

    let dyn [*]int = [1, 2, 3]
    dyn.push(4)
    let last int = dyn.pop()
    dyn.insert(1, 99)
    let removed int = dyn.remove(2)
    dyn.clear()
    dyn.reserve(100)

    let isEmpty bool = dyn.isEmpty()
    let length int = dyn.len()
    let cap int = dyn.cap()
    let first int = dyn.first()
    let lastElem int = dyn.last()

    -- Array concatenation (+)
    let aArr [*]int = [1,2]
    let bArr [*]int = [3,4]
    let cArr [*]int = aArr + bArr

    -- ========================================================================
    -- References (&T) and reference equality (===)
    -- ========================================================================
    let pointA Point = Point { x = 1, y = 2 }
    let ref pRef &Point = pointA
    pRef.x = 100              -- modifies pointA
    let pointB Point = pointA
    let ref pRef2 &Point = pointA
    let sameRef bool = pRef === pRef2   -- true
    let sameVal bool = pointA === pointB -- false (different addresses)

    -- ========================================================================
    -- any with is checks
    -- ========================================================================
    let anything any = 42
    if anything is int {
        let intVal int = anything   -- narrowing (semantic)
        io.printl("int: " + string(intVal))
    }

    -- ========================================================================
    -- Intrinsics (#sizeof, #alignof, #sqrt, #min, #max, #clz, etc.)
    -- ========================================================================
    let sz uint64 = #sizeof(Point)
    let align uint64 = #alignof(Point)
    let root float = #sqrt(16.0)
    let floorVal float = #floor(3.7)
    let ceilVal float = #ceil(3.2)
    let roundVal float = #round(3.5)
    let absVal int = #abs(-10)
    let powVal float = #pow(2.0, 3.0)
    let fmaVal float = #fma(2.0, 3.0, 1.0)   -- 7.0
    let minVal int = #min(10, 20)
    let maxVal int = #max(10, 20)
    let leading int = #clz(0b00110000)
    let trailing int = #ctz(0b00110000)
    let popcnt int = #popcount(0b110011)
    let swapped int = #bswap(0x12345678)

    -- ========================================================================
    -- Raw pointers and pointer intrinsics (only inside @extern functions)
    -- Declare an extern function and use in main? Not allowed because main
    -- is not @extern. But we can call an extern function that uses them.
    -- Already tested in separate extern function. Here just call it.
    -- ========================================================================
    @extern("test")
    const pointerDemo () -> int

    let demoResult int = pointerDemo()

    -- ========================================================================
    -- async/await (only inside ~async function)
    -- ========================================================================
    let asyncMain ~async () -> int = {
        let data string = await asyncFetch("https://example.com")
        return data.len()
    }
    -- Cannot call await in non-async main, so we just define.

    -- ========================================================================
    -- from implicit conversion (already tested via struct Feet)
    -- ========================================================================
    let meters Meters = Meters { value = 10.0 }
    let feet Feet = meters   -- implicit via from Feet

    -- ========================================================================
    -- Type alias usage
    -- ========================================================================
    let id IntAlias = 100
    let maybeInt NullableInt = nil

    -- ========================================================================
    -- Enum variant access
    -- ========================================================================
    let selected Color = Color.Red

    -- ========================================================================
    -- Struct literal with defaults
    -- ========================================================================
    struct Defaults {
        a int = 1
        b string = "default"
    }
    let def Defaults = Defaults { a = 42 }   -- b uses default

    -- ========================================================================
    -- Return statement (end of main)
    -- ========================================================================
    return 0
}