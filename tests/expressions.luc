    -- b %= 3
    -- a &&= 0xFF      -- bitwise AND assign
    -- b ||= 0x0F      -- bitwise OR assign
    -- a ~^= 0xAA      -- bitwise XOR assign
    -- b <<= 1
    -- b >>= 1

    -- -- ========================================================================
    -- -- If statement (type narrowing with `is`)
    -- -- ========================================================================
    -- if c is int {
