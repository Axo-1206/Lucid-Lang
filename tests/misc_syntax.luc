package test

-- ============================================================================
-- Module system (use declarations - parser must accept, even if linking later)
-- ============================================================================

use math                         -- all exported items
use math.vec2                    -- specific file
use math as m                    -- alias
export use math.vec2             -- re-export
export use math.matrix.Mat2      -- granular re-export

-- ============================================================================
-- Doc comments (attached to following declaration)
-- ============================================================================

/--
 - This is a doc comment for the Config struct.
 - It supports Markdown.
--/
struct Config {
    timeout int = 30
}

-- Single-line doc comment attached to function
-- Returns the square of a number.
let square (x int) -> int = { return x * x }

-- ============================================================================
-- If expression (if cond ?? then else)
-- ============================================================================

let status int = 200
let message string = if status == 200 ?? "OK" else "Error"

-- Chained if expression (right-associative)
let code int = -5
let label string = if code < 0 ?? "negative" else if code == 0 ?? "zero" else "positive"

-- ============================================================================
-- Null-coalescing operator (??)
-- ============================================================================

let maybeValue int? = nil
let fallback int = maybeValue ?? 42

let config string? = nil
let useConfig string = config ?? "default"

-- ============================================================================
-- Safe navigation operator (?.)
-- ============================================================================

struct User {
    name string
    address &Address?
}

struct Address {
    city string
}

let user User? = nil
let cityName string? = user?.address?.city   -- nil if any step is nil

let validUser User = User { name = "Alice", address = nil }
let city string? = validUser?.address?.city   -- nil because address is nil

-- ============================================================================
-- Catch step (|> catch)
-- ============================================================================

let safeDivide (a int, b int) -> int, Error? = {
    if b == 0 { return 0, Error { msg = "division by zero" } }
    return a / b, nil
}

let result int = safeDivide(10, 0) |> catch(err) {
    io.printl("Error: " + err.msg)
    return -1
}

-- ============================================================================
-- Power operator (^) - right-associative
-- ============================================================================

let base int = 2
let exp int = 3
let power int = base ^ exp      -- 8
let rightAssoc int = 2 ^ 3 ^ 2  -- 2 ^ (3 ^ 2) = 2 ^ 9 = 512

-- ============================================================================
-- Variadic parameters
-- ============================================================================

let sum (numbers ...int) -> int = {
    let total int = 0
    for i int in 0..<numbers.len() {
        total = total + numbers[i]
    }
    return total
}

let average (first int, rest ...int) -> float = {
    let total int = first + sum(rest...)
    return float(total) / float(1 + rest.len())
}

-- ============================================================================
-- For loop with step
-- ============================================================================

let evenSum (limit int) -> int = {
    let total int = 0
    for i int in 0..limit..2 {
        total = total + i
    }
    return total
}

-- ============================================================================
-- Array concatenation (+)
-- ============================================================================

let a [*]int = [1, 2, 3]
let b [*]int = [4, 5, 6]
let c [*]int = a + b      -- [1,2,3,4,5,6]

let sliceA []int = a[0..<2]
let sliceB []int = b[0..<2]
let sliceSum []int = sliceA + sliceB   -- slice concatenation

-- ============================================================================
-- #sizeof, #alignof compile-time intrinsics
-- ============================================================================

struct Vertex {
    x float
    y float
    z float
}

let vertexSize uint64 = #sizeof(Vertex)
let vertexAlign uint64 = #alignof(Vertex)
let intSize uint64 = #sizeof(int)

-- ============================================================================
-- #memcpy, #memset, #memmove (inside @extern function)
-- ============================================================================

@extern("stdlib")
const malloc (size uint64) -> *uint8?

@extern("stdlib")
const free (ptr *uint8)

let copyMemory () -> int = {
    let src *uint8? = malloc(100)
    let dst *uint8? = malloc(100)
    if src == nil or dst == nil { return 1 }

    #memcpy(dst, src, 100)
    #memset(src, 0, 100)
    #memmove(dst, src, 50)

    free(src)
    free(dst)
    return 0
}

-- ============================================================================
-- #bitcast (requires --unsafe or inside @extern)
-- ============================================================================

@extern("example")
const reinterpret () -> float32 = {
    let bits uint32 = 0x3F800000
    let f float32 = #bitcast(float32, bits)   -- 1.0
    return f
}

