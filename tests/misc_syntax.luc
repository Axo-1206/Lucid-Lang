-- Raw string literals (r"...")
-- ============================================================================

let regex string = r"^\d{3}-\d{2}-\d{4}$"
let path string = r"C:\Users\name\file.txt"
let rawWithQuotes string = r"He said "Hello""

-- ============================================================================
-- Char literals with escapes
-- ============================================================================

let newline char = '\n'
let tab char = '\t'
let hexChar char = '\xFF'
let unicodeChar char = '\u0041'    -- 'A'
let largeUnicode char = '\U0001F600' -- 😀

-- ============================================================================
-- from with generic parameters
-- ============================================================================

struct Wrapper<T> {
    value T
}

struct Unwrapped<T> {
    inner T
}

from Unwrapped<T> {
    (w Wrapper<T>) Unwrapped<T> = {
        return Unwrapped<T> { inner = w.value }
    }
}

let wrapped Wrapper<int> = Wrapper<int> { value = 42 }
let unwrapped Unwrapped<int> = wrapped   -- implicit conversion via from

-- ============================================================================
-- type alias with generic parameters
-- ============================================================================

type Option<T> = T?
type Result<T, E> = T?   -- simplified; actual would be union but Luc doesn't have unions
type MapFn<K, V> = (key K) -> V

-- ============================================================================
-- Qualifiers on type aliases (already tested, but include generic variant)
-- ============================================================================

type AsyncMap<T, U> = ~async (item T) -> U

-- ============================================================================
-- main entry point with @aot
-- ============================================================================

@aot
export const main (args []string) -> int = {
    io.printl("Hello from AOT compiled Luc")
    return 0
}

-- ============================================================================
-- Combined operator tests (compound assignment, etc.)
-- ============================================================================

let modify (x int) -> int = {
    let y int = 10
    y += x      -- y = y + x
    y *= 2
    y &&= 0xFF  -- bitwise AND assign
    y ||= 0x01  -- bitwise OR assign
    y ~^= 0xAA  -- bitwise XOR assign
    y <<= 1
    y >>= 1
    return y
}

-- ============================================================================
-- Power assignment (^=) - not in grammar? Grammar has '^=' in assign_op. Yes.
-- ============================================================================

let powerAssign (a int, b int) -> int = {
    let result int = a
    result ^= b     -- result = result ^ b (power, not XOR)
    return result
}

-- ============================================================================
-- Additional intrinsics not yet tested
-- ============================================================================

let fmaDemo (a float, b float, c float) -> float = {
    return #fma(a, b, c)   -- a*b + c
}

let minMax (a int, b int) -> int, int = {
    return #min(a, b), #max(a, b)
}

let bitOps (x uint32) -> uint32, uint32, uint32 = {
    let leading uint32 = #clz(x)
    let trailing uint32 = #ctz(x)
    let pop uint32 = #popcount(x)
    let swapped uint32 = #bswap(x)
    return leading, trailing, pop, swapped
}

-- ============================================================================
-- ??= operator? Not in grammar. But we have '??' as binary.
-- ============================================================================

let nullableCounter int? = nil
let counter int = nullableCounter ?? 0   -- not assignment

-- ============================================================================
-- not operator (logical not)
-- ============================================================================

let isReady bool = false
let notReady bool = not isReady

-- ============================================================================
-- and / or with nullable semantics
-- ============================================================================

let getFlag () -> bool? = nil
if getFlag() and isReady {   -- nil treated as false, short-circuit
    io.printl("both true")
}
if getFlag() or isReady {
    io.printl("at least one true")
}