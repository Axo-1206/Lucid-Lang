    -- 1. Testing Bitwise AND (&&), OR (||), and XOR (^^)
    var a = 0b1010  -- 10 in decimal
    var b = 0b1100  -- 12 in decimal

    var and_res = a && b   -- Expect 1000 (8)
    var or_res  = a || b   -- Expect 1110 (14)
    var xor_res = a ^^ b   -- Expect 0110 (6)

    -- 2. Testing Shift Operators (<<, >>)
    var base = 1
    var shift_left = base << 3  -- 1 * 2^3 = 8
    var shift_right = 16 >> 2   -- 16 / 2^2 = 4

    -- 3. Testing Exponential (^) - Right Associative
    -- Math: 2 ^ 3 ^ 2 should be 2 ^ (3 ^ 2) = 2 ^ 9 = 512
    -- If it were Left Associative, it would be (2 ^ 3) ^ 2 = 8 ^ 2 = 64
    var power_res = 2 ^ 3 ^ 2

    -- 4. Testing Combined Precedence
    -- Bitwise should be lower than addition: 1 << 2 + 1 
