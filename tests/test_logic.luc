fn main() {
    var health = 50.0
    var energy = 10
    var is_poisoned = true

    player.id = 6
    player.:call().id[0] = 6
    
    /-Valid Tests

    -- 1. Testing If-Else and Else-If (Recursive nesting)
    if health > 80.0 {
        print("Healthy")
    } else if health > 20.0 {
        print"Injured"
    } else {
        print("Danger")
    }

    -- 2. Testing Logic Operators (and, or, not)
    if is_poisoned and health > 0.0 {
        health = health - 5.0
    }

    if health <= 0.0 or energy == 0 {
        print("Game Over")
    }

    
    -- 3. Testing While Loop
    while energy > 0 {
        energy = energy - 1
        if (energy == 5) {
            continue -- Skip rest of body when energy is 5
        }
        print("Working...")
    }

     -- 4. Testing Do-While Loop
    var count = 0
    do {
        count = count + 1
    } while count < 5   

    -- 5. Testing Traditional For Loop
    var sum = 0

    for i = 0; i < 10; 1 {
        sum = sum + i
        if sum > 20 {
            break -- Exit loop early
        }

    }

    -- 6. Testing For-Each Loop
    var inventory [string] = ["sword", "shield", "potion"]
    for item in inventory {
        print(item)
    }

    -- Test: Do-While Loop
    var count = 0
    do {
        count = count + 1
        print("Loop iteration: ")
        print(count)
    } while count < 5

    -- Syntax: for key, value in collection { ... }
    for i, item in inventory {
        print("Slot: ")
