package test

-- 1. Simple enum
pub enum Direction {
    North
    South
    East
    West
}

-- 2. Enum with explicit values
enum ShaderStage {
    Vertex   = 0x01
    Fragment = 0x02
    Compute  = 0x04
}

-- 3. Using enum in a variable (type annotation required)
let dir Direction = Direction.North

-- 4. Switch statement (no fallthrough)
let describeDirection (d Direction) -> string = {
    switch d {
        case Direction.North: { return "up" }
        case Direction.South: { return "down" }
        case Direction.East:  { return "right" }
        case Direction.West:  { return "left" }
        default: { return "unknown" }
    }
}

-- 5. Match expression with enum (already tested partially, but show enum patterns)
let dirCode int = match dir {
    Direction.North => 0
    Direction.South => 1
    Direction.East  => 2
    Direction.West  => 3
    default         => -1
}

-- 6. `is` type check with narrowing
let process (value any) -> string = {
    if value is int {
        -- value narrowed to int here (in statement form)
        return "int: " + string(value)
    }
    if value is Direction {
        return "direction: " + string(value)  -- custom string conversion
    }
    return "unknown"
}

-- 7. `any` boxing
let boxed any = Direction.North   -- enum value boxed
let unboxed Direction = boxed     -- requires `is` check or unsafe cast? Not shown in grammar.
                                 -- But `is` works: if boxed is Direction { ... }

-- 8. While and do-while loops
let countDown (n int) -> int = {
    let i int = n
    while i > 0 {
        i = i - 1
    }
    return i
}

let doWhileExample (start int) -> int = {
    let i int = start
    do {
        i = i - 1
    } while i > 0
    return i
}

-- 9. Break and continue
let sumUntilZero (nums [*]int) -> int = {
    let total int = 0
    for i int in 0..<nums.len() {
        if nums[i] == 0 { break }
        if nums[i] < 0 { continue }
        total = total + nums[i]
    }
    return total
}

-- 10. Bitwise operators
let bitwiseDemo (a int, b int) -> (int, int, int, int) = {
    let andVal int = a && b
    let orVal  int = a || b
    let xorVal int = a ~^ b
    let notVal int = ~~a
    return andVal, orVal, xorVal, notVal
}

-- 11. Slice range expressions (not inside for)
let getSlice (arr [*]int) -> ([]int, []int) = {
    let inclusive []int = arr[1..3]
    let exclusive []int = arr[1..<3]
    return inclusive, exclusive
}