-- test/type_ex.luc
package test

-- ============================================================================
-- 1. Extending a struct with a namespace
-- ============================================================================
struct Vec2 {
    x float
    y float
}

extension Vec2 math {
    -- static method, first argument is the value
    let length (v Vec2) -> float = {
        return #sqrt(v.x * v.x + v.y * v.y)
    }

    let normalize (v Vec2) -> Vec2 = {
        let len float = Vec2::math.length(v)
        if len == 0.0 {
            return Vec2 { x = 0.0, y = 0.0 }
        }
        return Vec2 { x = v.x / len, y = v.y / len }
    }
}

-- Usage
let p Vec2 = Vec2 { x = 3.0, y = 4.0 }
let l float = Vec2::math.length(p)          -- 5.0
let norm Vec2 = Vec2::math.normalize(p)

-- ============================================================================
-- 2. Extending an enum
-- ============================================================================
enum Direction {
    North
    South
    East
    West
}

extension Direction helpers {
    let isNorth (d Direction) -> bool = {
        return d == Direction.North
    }
    let toInt (d Direction) -> int = {
        match d {
            Direction.North => 0
            Direction.South => 1
            Direction.East  => 2
            Direction.West  => 3
            default => -1
        }
    }
}

let d Direction = Direction.North
let b bool = Direction::helpers.isNorth(d)   -- true
let i int = Direction::helpers.toInt(d)      -- 0

-- ============================================================================
-- 3. Extending a primitive via type alias
-- ============================================================================
type IntOps = int

extension IntOps std {
    let abs (x int) -> int = {
        return #abs(x)
    }
    let clamp (x int, lo int, hi int) -> int = {
        return #min(#max(x, lo), hi)
    }
    let isEven (x int) -> bool = {
        return x % 2 == 0
    }
}

let neg int = -42
let pos int = IntOps::std.abs(neg)            -- 42
let clamped int = IntOps::std.clamp(100, 0, 50)   -- 50
let even bool = IntOps::std.isEven(10)        -- true

-- ============================================================================
-- 4. Extending a function type via type alias
-- ============================================================================
type Filter = (value int) -> bool

extension Filter combinators {
    let andThen (f Filter, g Filter) -> Filter = {
        return (x int) -> bool { return f(x) and g(x) }
    }
    let orElse (f Filter, g Filter) -> Filter = {
        return (x int) -> bool { return f(x) or g(x) }
    }
}

let isPositive Filter = (x int) -> bool { return x > 0 }
let isEvenFn Filter = (x int) -> bool { return x % 2 == 0 }

let isPosAndEven Filter = Filter::combinators.andThen(isPositive, isEvenFn)
let test bool = isPosAndEven(4)               -- true

-- ============================================================================
-- 5. Extending an array type via type alias
-- ============================================================================
type IntSlice = []int

extension IntSlice utils {
    let sum (arr []int) -> int = {
        let s int = 0
        for v in arr {
            s += v
        }
        return s
    }
    let max (arr []int) -> int? = {
        if arr.len() == 0 {
            return nil
        }
        let m int = arr[0]
        for i in 1..<arr.len() {
            if arr[i] > m {
                m = arr[i]
            }
        }
        return m
    }
}

let numbers IntSlice = [10, 20, 30, 40, 50]
let total int = IntSlice::utils.sum(numbers)          -- 150
let maximum int? = IntSlice::utils.max(numbers)       -- 50

-- ============================================================================
-- 6. Generic extension block
-- ============================================================================
struct Wrapper<T> {
    value T
}

extension Wrapper<T> container {
    let unwrap (w Wrapper<T>) -> T = {
        return w.value
    }
    let map (w Wrapper<T>, f (p T) -> U) -> Wrapper<U> = {
        return Wrapper<U> { value = f(w.value) }
    }
}

let wrappedInt Wrapper<int> = Wrapper<int> { value = 42 }
let val int = Wrapper<int>::container.unwrap(wrappedInt)      -- 42

let wrappedFloat  Wrapper<int> = Wrapper<int>::container.map(wrappedInt, (x int) -> float { return float(x) })
let fval float = Wrapper<float>::container.unwrap(wrappedFloat)   -- 42.0

