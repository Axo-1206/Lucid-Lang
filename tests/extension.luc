-- ============================================================================
-- 8. Extension on a type alias that itself aliases a primitive
-- ============================================================================
type FloatMath = float

extension FloatMath math {
    let square (x float) -> float = { return x * x }
    let cube (x float) -> float = { return x * x * x }
}

let sq float = FloatMath::math.square(5.0)       -- 25.0
let cb float = FloatMath::math.cube(3.0)         -- 27.0

-- ============================================================================
-- 9. Extension on a type alias for dynamic array
-- ============================================================================
type ByteBuffer = [*]byte

extension ByteBuffer buffer {
    let toHex (buf [*]byte) -> string = {
        let hexChars string = "0123456789ABCDEF"
        -- let result [*]char = []
        for b in buf {
            let high int = (b >> 4) && 0x0F
            let low int = b && 0x0F
            result.push(hexChars[high])
            result.push(hexChars[low])
        }
        return string(result)
    }
}

let data ByteBuffer = [0xDE, 0xAD, 0xBE, 0xEF]
let hex string = ByteBuffer::buffer.toHex(data)   -- "DEADBEEF"

