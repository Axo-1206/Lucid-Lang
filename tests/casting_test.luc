package tests

-- casting_test.luc
-- Exercises every form of 'from' block type casting in Luc.
--
-- Test categories:
--   1.  Basic implicit cast in variable declaration  (let x T = source)
--   2.  Explicit call syntax                         (T(source))
--   3.  Multiple from entries on one target          (overload by source type)
--   4.  Chained / multi-hop casts
--   5.  Pub / export visibility
--   6.  Cast used inside struct literal field
--   7.  Cast used as function argument
--   8.  Cast used as return value
--   9.  Cast in assignment statement                 (x = source)
--   10. Cast in pipeline step

-- 1. UNIT TYPES  (classic newtype-wrapper pattern)
--    Seconds, Minutes, Hours  all carry a single int field 'val'.
--    Converting between them is pure arithmetic.

pub struct Seconds { val int }
pub struct Minutes { val int }
pub struct Hours   { val int }

-- from Minutes accepts a Seconds value and a float (for fractional minutes)
pub from Minutes {
    -- Implicit cast:  let m Minutes = someSeconds
    (s Seconds) Minutes = {
        return Minutes { val = s.val / 60 }
    }

    -- Explicit call:  let m Minutes = Minutes(someHours)
    (h Hours) Minutes = {
        return Minutes { val = h.val * 60 }
    }
}

pub from Hours {
    (m Minutes) Hours = {
        return Hours { val = m.val / 60 }
    }

    (s Seconds) Hours = {
        return Hours { val = s.val / 3600 }
    }
}

pub from Seconds {
    (m Minutes) Seconds = {
        return Seconds { val = m.val * 60 }
    }

    (h Hours) Seconds = {
        return Seconds { val = h.val * 3600 }
    }
}


-- 2. TEMPERATURE TYPES
--    A multi-source target: Fahrenheit can be built from Celsius OR Kelvin.

pub struct Celsius    { val float }
pub struct Fahrenheit { val float }
pub struct Kelvin     { val float }

pub from Fahrenheit {
    (c Celsius) Fahrenheit = {
        return Fahrenheit { val = c.val * 9.0 / 5.0 + 32.0 }
    }

    (k Kelvin) Fahrenheit = {
        return Fahrenheit { val = (k.val - 273.15) * 9.0 / 5.0 + 32.0 }
    }
}

pub from Celsius {
    (f Fahrenheit) Celsius = {
        return Celsius { val = (f.val - 32.0) * 5.0 / 9.0 }
    }

    (k Kelvin) Celsius = {
        return Celsius { val = k.val - 273.15 }
    }
}

pub from Kelvin {
    (c Celsius) Kelvin = {
        return Kelvin { val = c.val + 273.15 }
    }
}


-- 3. DISTANCE TYPES
--    Used to test cast-as-argument and cast-as-return-value.


pub struct Meters     { val float }
pub struct Kilometers { val float }
pub struct Miles      { val float }

pub from Kilometers {
    (m Meters) Kilometers = {
        return Kilometers { val = m.val / 1000.0 }
    }

    (mi Miles) Kilometers = {
        return Kilometers { val = mi.val * 1.60934 }
    }
}

pub from Meters {
    (km Kilometers) Meters = {
        return Meters { val = km.val * 1000.0 }
    }
}

pub from Miles {
    (km Kilometers) Miles = {
        return Miles { val = km.val / 1.60934 }
    }
}

-- 4. HELPER FUNCTIONS  (used to test cast-as-argument and cast-as-return)

-- Accepts a Kilometers value and returns its numeric value doubled.
const doubleKm (km Kilometers) float = {
    return km.val * 2.0
}

-- Accepts Minutes, returns int val.
const minuteVal (m Minutes) int = {
    return m.val
}

-- Returns a Celsius value so callers can test cast-as-return.
const freezingPoint () Celsius = {
    return Celsius { val = 0.0 }
}

-- Accepts a Fahrenheit and returns float.
const toFahrenheitVal (f Fahrenheit) float = {
    return f.val
}


-- 5. MAIN — all cast scenarios exercised


export const main () int = {

    -- Category 1: implicit cast in let declaration 
    --
    -- The compiler desugars  `let m Minutes = s`  into  `let m Minutes = Minutes(s)`
    -- by detecting that Minutes has a from-entry accepting Seconds.

    let rawSecs Seconds = Seconds { val = 3600 }

    -- Seconds → Minutes  (implicit, desugared by semantic pass)
    let m1 Minutes = rawSecs
    -- Expected: m1.val == 60  (3600 / 60)

    -- Seconds → Hours  (implicit)
    let h1 Hours = rawSecs
    -- Expected: h1.val == 1  (3600 / 3600)

    -- Minutes → Hours  (implicit, different source type)
    let rawMins Minutes = Minutes { val = 120 }
    let h2 Hours = rawMins
    -- Expected: h2.val == 2  (120 / 60)


    -- ── Category 2: explicit call syntax 
    --
    -- TypeName(expr) is always valid regardless of implicit-cast support.
    -- The parser produces a TypeConvExprAST; the semantic pass dispatches
    -- to the matching from-entry.

    let rawHours Hours = Hours { val = 2 }

    -- Hours → Minutes  (explicit)
    let m2 Minutes = Minutes(rawHours)
    -- Expected: m2.val == 120  (2 * 60)

    -- Seconds → Hours  (explicit)
    let h3 Hours = Hours(rawSecs)
    -- Expected: h3.val == 1

    -- Minutes → Seconds  (explicit, round-trip)
    let s2 Seconds = Seconds(m1)
    -- Expected: s2.val == 3600  (60 * 60)


    -- ── Category 3: multiple from entries on one target 
    --
    -- Fahrenheit has two from-entries: one for Celsius, one for Kelvin.
    -- The compiler selects the entry whose first param type matches the source.

    let boiling Celsius    = Celsius    { val = 100.0 }
    let absolute Kelvin    = Kelvin     { val = 373.15 }

    -- Celsius → Fahrenheit  (implicit, picks the Celsius entry)
    let f1 Fahrenheit = boiling
    -- Expected: f1.val ≈ 212.0

    -- Kelvin → Fahrenheit  (implicit, picks the Kelvin entry)
    let f2 Fahrenheit = absolute
    -- Expected: f2.val ≈ 212.0  (373.15 K ≈ 100 °C)

    -- Kelvin → Celsius  (implicit)
    let c1 Celsius = absolute
    -- Expected: c1.val ≈ 100.0  (373.15 - 273.15)


    -- ── Category 4: chained / multi-hop casts 
    --
    -- Each hop is a separate let binding; the compiler applies one implicit
    -- cast per binding. There is no automatic multi-hop desugaring — the
    -- programmer writes each step explicitly.

    let rawSecs2 Seconds = Seconds { val = 7200 }

    -- Hop 1: Seconds → Minutes
    let mins2 Minutes = rawSecs2
    -- Expected: mins2.val == 120

    -- Hop 2: Minutes → Hours
    let hrs2 Hours = mins2
    -- Expected: hrs2.val == 2


    -- ── Category 5: cast inside struct literal field 
    --
    -- A struct field whose declared type is T and the supplied value is S
    -- triggers the same from-cast desugaring inside the struct literal checker.


    -- ── Category 6: cast as function argument 
    --
    -- When a function parameter type is T and the caller passes a value of
    -- type S, the semantic pass desugars the argument into T(s) if a matching
    -- from-entry exists.

    let trackDist Meters = Meters { val = 5000.0 }

    -- doubleKm expects Kilometers; we pass Meters.
    -- The call-site arg should be desugared to Kilometers(trackDist).
    let doubled float = doubleKm(Kilometers(trackDist))
    -- Expected: doubled == 10.0  (5000 / 1000 * 2)

    -- minuteVal expects Minutes; we pass Seconds.
    let durSec Seconds = Seconds { val = 300 }
    let durMin int = minuteVal(Minutes(durSec))
    -- Expected: durMin == 5  (300 / 60)


    -- ── Category 7: cast as function return value 
    --
    -- freezingPoint() returns Celsius { val = 0.0 }.
    -- Assigning that to a Fahrenheit variable triggers an implicit cast.

    let freezF Fahrenheit = freezingPoint()
    -- Expected: freezF.val == 32.0  (0 °C in Fahrenheit)


    -- ── Category 8: cast in assignment statement  x = expr 
    --
    -- The same desugaring applies when a let variable is reassigned, not just
    -- when it is first declared.

    let currentTemp Fahrenheit = Fahrenheit { val = 70.0 }
    let newReading Celsius     = Celsius    { val = 37.0 }  -- body temperature

    -- Reassign currentTemp from a Celsius value (implicit desugaring).
    currentTemp = newReading
    -- Expected: currentTemp.val ≈ 98.6  (37 * 9/5 + 32)


    -- ── Category 9: cast in pipeline 
    --
    -- toFahrenheitVal accepts Fahrenheit. Piping a Celsius into it requires
    -- an explicit cast in the pipeline step (the pipeline does not auto-cast).
    -- We use the explicit call form inside the step as the clearest style.

    let bodyC Celsius = Celsius { val = 37.0 }
    let bodyFVal float = Fahrenheit(bodyC) -> toFahrenheitVal
    -- Expected: bodyFVal ≈ 98.6


    return 0
}
