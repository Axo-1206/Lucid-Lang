package test

-- ============================================================================
-- TRAIT TESTS: Method contract declarations and impl conformance
-- ============================================================================

-- Test 1: Basic trait declaration with multiple methods
pub trait Drawable {
    draw () int
    getBounds () int
}

-- Test 2: Trait with parameters
pub trait Comparable {
    compare (other int) int
    isEqual (other int) int
}

-- Test 3: Generic trait
pub trait Container<T> {
    add (item T) int
    remove (item T) int
    get (index int) T
}

-- Test 4: Struct declarations for impl conformance tests
struct Circle {
    x float
    y float
    radius float
}

struct Rectangle {
    x float
    y float
    width float
    height float
}

struct IntList {
    values int
}

-- ============================================================================
-- IMPL BLOCKS: Single trait conformance
-- ============================================================================

-- Test 5: Single trait conformance with Circle
pub impl Circle : Drawable {
    draw () int = {
        return 0
    }

    getBounds () int = {
        return int(radius)
    }
}

-- Test 6: Single trait conformance with Rectangle
pub impl Rectangle : Drawable {
    draw () int = {
        return 1
    }

    getBounds () int = {
        return int(width)
    }
}

-- ============================================================================
-- IMPL BLOCKS: Multiple trait conformance (separate blocks)
-- ============================================================================

-- Test 7: Multiple traits on Circle - same method name, same signature
-- One implementation satisfies both traits
pub trait Drawable2 {
    render () int
}

pub trait Renderable {
    render () int
}

struct Scene {
    elements int
}

pub impl Scene : Drawable2 {
    render () int = {
        return 42
    }
}

-- This should work — same method, same signature satisfies both traits
pub impl Scene : Renderable {
    -- render() is already provided above, satisfying both traits
}

-- ============================================================================
-- IMPL BLOCKS: Multiple trait conformance (different methods)
-- ============================================================================

-- Test 8: Circle implementing Drawable + Comparable
pub impl Circle : Comparable {
    compare (other int) int = {
        return 1
    }

    isEqual (other int) int = {
        return 0
    }
}

-- ============================================================================
-- IMPL BLOCKS: Non-trait impl (basic methods)
-- ============================================================================

-- Test 9: Impl block without trait conformance (structural only)
pub impl Rectangle {
    -- Helper method - no trait requirement
    area () float = {
        return width
    }

    -- Curried method: partial application support
    expand (deltaW float) (deltaH float) Rectangle = {
        return Rectangle { x = x, y = y, width = width + deltaW, height = height + deltaH }
    }
}

-- ============================================================================
-- USAGE IN MAIN
-- ============================================================================

export const main () int = {
    -- Test Circle creation and method calls
    let c Circle = Circle { x = 0.0, y = 0.0, radius = 5.0 }
    let drawn int = c:draw()

    -- Test Rectangle creation and method calls
    let r Rectangle = Rectangle { x = 10.0, y = 20.0, width = 30.0, height = 40.0 }
    let area float = r:area()
    let expanded Rectangle = r:expand(5.0)(10.0)

    -- Test Scene with dual trait conformance
    let scene Scene = Scene { elements = 100 }
    let rendered int = scene:render()

    return 0
}