package oop -- tests/oop/main.luc
mod main

-- Import the module and give it the local name 'Player'
req Player = "oop/player.luc"

pub var x i32 = 10 + 5
const y = 20
var isDifferent bool = x != y

pub fn main() {
    -- Use the module name to call the 'static' new() function
    var player Player = Player.new()
    
    -- Use the receiver-based method
    player.dosomething()
}