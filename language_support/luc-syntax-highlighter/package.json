{
  "name": "luc-syntax-highlighter",
  "displayName": ".luc",
  "description": "default theme for luc",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "luc",
      "aliases": ["luc", "luc"],
      "extensions": [".luc"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "luc",
      "scopeName": "source.luc",
      "path": "./syntaxes/luc.tmLanguage.json"
    }],
    "snippets": [
        {
            "language": "luc",
            "path": "./snippets/luc.json"
        }
    ]
  }
}
